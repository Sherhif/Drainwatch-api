NODE_ENV=development
PORT=3000


API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:5173,https://drain-watch-nine.vercel.app
APP_NAME=DrainWatch API
APP_VERSION=0.0.1


JWT_SECRET=change-me
JWT_EXPIRES_IN=1d
OTP_BYPASS_ENABLED=true


DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=drainwatch
DB_SSL=false
DB_SYNCHRONIZE=true
DB_MIGRATIONS_RUN=false


CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_REPORT_FOLDER=drainwatch/report-photos
CLOUDINARY_COMPLETION_FOLDER=drainwatch/completion-photos


MOOLRE_MODE=stub
MOOLRE_PAYMENTS_MODE=stub
MOOLRE_SMS_MODE=stub
MOOLRE_BASE_URL=
MOOLRE_COLLECTIONS_PATH=/open/transact/payment
MOOLRE_DISBURSEMENTS_PATH=/open/transact/transfer
MOOLRE_REFUNDS_PATH=/open/transact/transfer
MOOLRE_PAYMENT_STATUS_PATH=/open/transact/status
MOOLRE_WEBHOOK_SECRET=
MOOLRE_SMS_PATH=/open/sms/send
MOOLRE_SMS_SENDER_ID=DrainWatch
MOOLRE_API_USER=
MOOLRE_API_KEY=
MOOLRE_API_PUBKEY=
MOOLRE_API_VASKEY=
MOOLRE_BUSINESS_WALLET_REF=
